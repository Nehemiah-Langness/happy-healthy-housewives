{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3500",
      "webRoot": "${workspaceFolder}/src",
      "sourceMapPathOverrides": {
